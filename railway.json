{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm start",
    "healthcheck": {
      "contentType": "application/json",
      "interval": 10,
      "path": "/",
      "successCodes": [200, 304],
      "timeout": 5
    }
  }
}
